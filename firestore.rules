rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function hasValidOptionalUid(userId) {
      return !('uid' in request.resource.data) || request.resource.data.uid == userId;
    }

    function eventEnvelopeIsValid(userId) {
      return request.resource.data.uid == userId
        && request.resource.data.keys().hasAll([
          'eventId',
          'eventName',
          'uid',
          'timestamp',
          'source',
          'schemaVersion',
          'payloadVersion',
          'payload',
          'deviceId',
          'appVersion'
        ]);
    }

    function rootServerFieldsUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['uid', 'createdAt', 'schemaVersion']);
    }

    match /users/{userId} {
      // Root user document
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && hasValidOptionalUid(userId);
      allow update: if isOwner(userId)
        && hasValidOptionalUid(userId)
        && rootServerFieldsUnchanged();
      allow delete: if isOwner(userId);

      // General subcollections — owner full access.
      // Collections with tighter rules are carved out and matched below.
      match /{collectionId}/{document=**} {
        allow read: if isOwner(userId)
          && !(collectionId in [
            'events', 'events_recent',
            'deletion_requests', 'data_exports'
          ]);
        allow create, update: if isOwner(userId)
          && hasValidOptionalUid(userId)
          && !(collectionId in [
            'events', 'events_recent',
            'deletion_requests', 'data_exports'
          ]);
        allow delete: if isOwner(userId)
          && !(collectionId in [
            'events', 'events_recent',
            'deletion_requests', 'data_exports'
          ]);
      }

      // ── Events (append-only audit log) ─────────────────────────────────
      // update/delete are permanently closed; uid in the doc must match owner.
      match /events/{eventId} {
        allow read:   if isOwner(userId);
        allow create: if isOwner(userId)
          && eventEnvelopeIsValid(userId)
          && request.resource.data.eventId == eventId;
        allow update, delete: if false;
      }

      // ── events_recent (trimmed fast-access cache) ───────────────────────
      // Same immutability contract as /events; trimming is done by Cloud Functions.
      match /events_recent/{eventId} {
        allow read:   if isOwner(userId);
        allow create: if isOwner(userId)
          && eventEnvelopeIsValid(userId)
          && request.resource.data.eventId == eventId;
        allow update, delete: if false;
      }

      // ── Deletion requests (client creates once; admin SDK finalises) ────
      match /deletion_requests/{requestId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidOptionalUid(userId);
        allow update, delete: if false;
      }

      // ── Data export requests (client triggers; system writes result) ────
      match /data_exports/{exportId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidOptionalUid(userId);
        allow update, delete: if false;
      }
    }

    // App config — read-only for authenticated clients
    match /app_config/{doc} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // Crisis handoffs — admin SDK only, never from the client
    match /crisis_handoffs/{doc} {
      allow read, write: if false;
    }
  }
}
